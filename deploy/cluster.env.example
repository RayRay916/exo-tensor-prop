# ── exo-tensor-prop cluster config ──────────────────────────────────────────
# Copy this file to `cluster.env` (gitignored) and fill in your own cluster.
# Every script in deploy/ sources cluster.env at startup.

# SSH hostnames of the worker nodes (rank1..N), space-separated, in rank order.
# The master (rank0) is whatever host you run `exoprop` from. Use ~/.ssh/config
# aliases — never user@ip.
EXO_WORKERS="worker-a worker-b worker-c"

# "Anchor" IPs that firewalled laptop workers dial to fetch the current libp2p
# peer-id for bootstrap (mDNS can't reach them). Space-separated. Typically the
# always-on desktop nodes. Leave empty if every node is mDNS-reachable.
EXO_ANCHOR_IPS="10.0.0.1 10.0.0.2"

# Path to THIS fork's exo executable (built into its venv) on EVERY node.
EXO_BIN="$HOME/exo-tensor-prop/.venv/bin/exo"

# Path to the deploy/ dir on each worker (must be checked out at the same place).
EXO_REMOTE_DEPLOY_DIR="$HOME/exo-tensor-prop/deploy"

# Isolation: dedicated ports + EXO_HOME + libp2p namespace so this cluster never
# collides with a stock exo cluster on the same tailnet.
EXO_PROP_API_PORT=52416
EXO_PROP_LIBP2P_PORT=52417
EXO_PROP_HOME=".exo-prop"
EXO_PROP_NAMESPACE="prop-3node"

# Continuous-batch concurrency per instance.
EXO_MAX_CONCURRENT_REQUESTS=4

# Where shared model weights live (read-only on workers).
EXO_MODELS_READ_ONLY_DIRS="$HOME/.exo/models"

# Regex matching this fork's exo binary, used by `exoprop stop` to pkill only
# this cluster's processes. Keep it specific to this checkout's venv path.
EXO_BIN_RE="exo-tensor-prop/[.]venv/bin/exo"

# Model IDs for the `exoprop start <shortcut>` convenience targets. Replace with
# your own HF repo ids (or ignore the shortcuts and use `exoprop start load <id>`).
MODEL_35B="org/your-35b-moe-model"
MODEL_122B="org/your-122b-moe-model"
MODEL_ASSISTANT="org/your-assistant-model"
